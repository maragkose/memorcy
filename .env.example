# SurrealDB connection
MEM_DB_URL=ws://127.0.0.1:8000/rpc
MEM_DB_USER=root
MEM_DB_PASS=root
MEM_DB_NS=memento
MEM_DB_DB=memory

# Enrichment provider: deterministic | ollama | openai | gemini
MEM_ENRICH=deterministic

# Embeddings provider: none | ollama | openai | transformers
MEM_EMBED=none

# Ollama (if used)
MEM_OLLAMA_URL=http://127.0.0.1:11434
MEM_OLLAMA_MODEL=llama3.1
MEM_OLLAMA_EMBED_MODEL=nomic-embed-text

# API keys (only if API providers selected)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Ingestion roots (defaults derived from $HOME if unset)
MEM_CURSOR_HOME=

# Rules-file injection (no-MCP fallback). The daemon writes an always-applied
# .mdc digest that any Cursor session reads automatically at start.
MEM_MDC=true
MEM_MDC_PATH=            # default: ~/.cursor/rules/memento.mdc
MEM_MDC_LIMIT=12         # max sessions in the digest
MEM_MDC_INTERVAL_MS=300000  # re-export cadence (5 min)

# Incremental ingest: the daemon polls sources for new/changed sessions and
# ingests them automatically (no manual backfill). Set MEM_INGEST_WATCH=false to
# disable and rely on manual `backfill` only.
MEM_INGEST_WATCH=true
MEM_INGEST_INTERVAL_MS=60000  # poll cadence (1 min)
